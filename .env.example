# Database
DATABASE_URL=postgresql://ticketing:ticketing123@db:5432/ticketing

# Redis
REDIS_URL=redis://cache:6379
REDIS_HOST=cache
REDIS_PORT=6379

# JWT (generate a strong random secret, min 32 chars)
JWT_SECRET=

# Cookie Secure flag (set to true behind TLS terminator; defaults to checking x-forwarded-proto)
COOKIE_SECURE=false
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# CORS
CORS_ORIGIN=https://helpdesk.rsmch.internal

# Database pool
DATABASE_POOL_MAX=10

# Upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=/app/uploads
BACKUP_DIR=/app/backups

# App
NODE_ENV=production
PORT=3000

# PostgreSQL
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing123
POSTGRES_DB=ticketing
