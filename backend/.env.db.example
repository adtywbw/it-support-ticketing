# Least-privilege env file for the `db` (PostgreSQL) compose service.
# Copy to backend/.env.db:  cp backend/.env.db.example backend/.env.db
#
# Values MUST match the corresponding fields in backend/.env so the API can
# connect to the database. Only DB-related variables are listed here on
# purpose (SEC-023) — the postgres container does not need JWT/Redis secrets.
#
# Generate a strong password:  openssl rand -base64 24
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=<replace-me-db-password>
POSTGRES_DB=ticketing
