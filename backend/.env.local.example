# Local development env for running the backend outside Docker.
NODE_ENV=development
PORT=3000

POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing123
POSTGRES_DB=ticketing
DATABASE_URL=postgresql://ticketing:ticketing123@localhost:5432/ticketing

REDIS_PASSWORD=redis-dev-password
REDIS_URL=redis://:redis-dev-password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=dev-only-secret-not-for-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
BACKUP_DIR=./backups
DATABASE_POOL_MAX=20
