# Application
NODE_ENV=development
PORT=3000

# Database
# For Docker (compose), use service host: postgres://user:password@db:5432/it_support_ticketing
# For local dev (outside Docker), use: postgres://user:password@localhost:5432/it_support_ticketing
DATABASE_URL=postgresql://user:password@localhost:5432/it_support_ticketing

# Postgres (used by docker-compose db service)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=it_support_ticketing

# JWT (generate a strong random secret, min 32 chars for production)
JWT_SECRET=dev-only-secret-not-for-production

# Cookie Secure flag (set to true behind TLS terminator; defaults to checking x-forwarded-proto)
COOKIE_SECURE=false
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Redis
# For Docker (compose), use: redis://:${REDIS_PASSWORD}@cache:6379
# For local dev (outside Docker), use: redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
BACKUP_DIR=./backups
