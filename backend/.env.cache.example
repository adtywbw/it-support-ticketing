# Least-privilege env file for the `cache` (Redis) compose service.
# Copy to backend/.env.cache:  cp backend/.env.cache.example backend/.env.cache
#
# The REDIS_PASSWORD value MUST match the password embedded in REDIS_URL in
# backend/.env so the API can authenticate to Redis. Only the Redis password
# is listed here on purpose (SEC-023) — the redis container does not need
# JWT/DB secrets.
#
# Generate a strong password (hex = URL-safe for REDIS_URL):  openssl rand -hex 24
REDIS_PASSWORD=<replace-me-redis-password>
