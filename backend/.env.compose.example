# Docker Compose canonical env file. Copy to backend/.env for docker compose.
NODE_ENV=production
PORT=3000

# Database inside compose network
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=<replace-me-db-password>
POSTGRES_DB=ticketing
DATABASE_URL=postgresql://ticketing:<replace-me-db-password>@db:5432/ticketing

# Redis inside compose network
REDIS_PASSWORD=<replace-me-redis-password>
REDIS_URL=redis://:<replace-me-redis-password>@cache:6379
REDIS_HOST=cache
REDIS_PORT=6379

# JWT. Use at least 32 random characters in production.
JWT_SECRET=<replace-me-min-32-chars>
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
COOKIE_SECURE=false

# HTTP origin used by the browser.
CORS_ORIGIN=http://helpdesk.rsmch.internal

# Optional Telegram fallback. Prefer Admin UI config later.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
BACKUP_DIR=/app/backups
