# Docker Compose canonical env file for the `api` service. Copy to backend/.env:
#   cp backend/.env.compose.example backend/.env
#
# Two companion least-privilege env files are also required by docker compose:
#   cp backend/.env.db.example    backend/.env.db    # `db` service (PostgreSQL)
#   cp backend/.env.cache.example backend/.env.cache # `cache` service (Redis)
# The POSTGRES_PASSWORD in .env.db and REDIS_PASSWORD in .env.cache MUST match
# the values embedded in DATABASE_URL / REDIS_URL below.
#
# This file ships with LOCAL HTTP defaults because the included nginx config
# listens on port 80 only (no TLS). Secure cookies require HTTPS, so
# COOKIE_SECURE=false is the correct default for the bundled compose stack.
#
# ── Production deployment (HTTPS) ──
#   Option A — External reverse proxy (nginx, Caddy, Traefik, ALB):
#     1. Put a TLS-terminating reverse proxy in front of the bundled nginx.
#     2. Set NODE_ENV=production, COOKIE_SECURE=true, HTTPS CORS_ORIGIN.
#     3. Provide strong secrets: `openssl rand -hex 24` (passwords, URL-safe)
#        and `openssl rand -hex 32` (JWT). Avoid -base64 (its / + = break URLs).
#     4. Set SEED_ADMIN_PASSWORD and SEED_SUPPORT_PASSWORD for first-run seed.
#     5. docker compose up --build -d
#   Option B — Bundled mkcert TLS (internal networks):
#     Same env as Option A, plus generate mkcert certs (see README), then:
#     docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build -d
#
# ── Local HTTP dev (bundled compose, no TLS) ──
#   Keep NODE_ENV=development and COOKIE_SECURE=false as shown below.
#   The app enforces COOKIE_SECURE=true when NODE_ENV=production, so do not
#   mix production NODE_ENV with HTTP-only nginx.
NODE_ENV=development
PORT=3000

# Database inside compose network
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=<replace-me-db-password>
POSTGRES_DB=ticketing
DATABASE_URL=postgresql://ticketing:<replace-me-db-password>@db:5432/ticketing

# Redis inside compose network
REDIS_PASSWORD=<replace-me-redis-password>
REDIS_URL=redis://:<replace-me-redis-password>@cache:6379
REDIS_HOST=cache
REDIS_PORT=6379

# JWT. Use at least 32 random characters in production.
JWT_SECRET=<replace-me-min-32-chars>
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
# Local HTTP dev: false. Production HTTPS: true (enforced when NODE_ENV=production).
COOKIE_SECURE=false

# HTTP origin used by the browser.
CORS_ORIGIN=http://helpdesk.rsmch.internal

# Optional Telegram fallback. Prefer Admin UI config later.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
BACKUP_DIR=/app/backups
DATABASE_POOL_MAX=20
